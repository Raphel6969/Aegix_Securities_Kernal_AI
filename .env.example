# Aegix Security System — Environment Configuration Template
# Copy this file to '.env' and fill in your actual credentials.

# Kernel Monitoring Ownership
# Options: 'backend' (default), 'agent', 'disabled'
KERNEL_MONITOR_OWNER=backend

# API Server Settings
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info

# Frontend CORS Origins (comma-separated list of allowed origins)
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Event Storage (relative or absolute path to SQLite database)
DB_PATH=data/events.db

# Event Cache Size (max events in memory)
EVENT_CACHE_SIZE=1000

# Agent Settings
BACKEND_URL=http://localhost:8000
AGENT_EVENT_TIMEOUT=5

# Frontend (Vite API Target)
VITE_API_URL=http://localhost:8000

# Groq AI Settings (Used for Tier C explanations & cybersecurity chatbot widget)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Gmail SMTP Settings (Used for email log audits)
# Note: GMAIL_APP_PASSWORD requires generating a Google App Password (not your standard password)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Optional: CC department email routing (JSON dictionary format)
# Note: Keep the single quotes surrounding the JSON to prevent system environment parsing issues
DEPARTMENT_EMAILS='{"SOC Operations": "soc@yourcompany.com", "Security Engineering": "security@yourcompany.com", "Incident Response": "ir@yourcompany.com"}'
